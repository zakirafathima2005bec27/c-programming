#include <stdlib.h>
#include <stdio.h>

char* intToRoman(int num) {
    int values[] = {1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1};
    char* symbols[] = {"M", "CM", "D", "CD", "C", "XC", "L", "XL", "X", "IX", "V", "IV", "I"};
    
    char* roman = (char*)malloc(16 * sizeof(char));
    roman[0] = '\0';

    for (int i = 0; i < 13; i++) {
        while (num >= values[i]) {
            int j = 0;
            int k = 0;
            while (roman[k] != '\0') k++;
            while (symbols[i][j] != '\0') {
                roman[k++] = symbols[i][j++];
            }
            roman[k] = '\0';
            num -= values[i];
        }
    }
    
    return roman;
}
